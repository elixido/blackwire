{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "outDir": "server/dist",
    "rootDir": ".",
    "types": ["node"],
    "noEmit": false
  },
  "include": ["server/src/**/*", "src/data/seed.ts", "src/lib/portraits.ts"]
}
